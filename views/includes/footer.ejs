<style>
  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }

  body {
    font-family: 'Roboto', sans-serif;
    background-color: #e0f7fa;
    color: #212529;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body.dark-mode {
    background-color: #212529;
    color: #f8f9fa;
  }

  body.dark-mode a {
    color: #f8f9fa;
  }

  body.dark-mode .f-socials a:hover,
  body.dark-mode .f-links a:hover {
    color: #ffc107;
  }

  body.dark-mode .back-to-top:hover {
    transform: translateY(-4px);
  }

  footer {
    background-color: #81d4fa;
    color: #212529;
    padding: 1rem 0;
    transition: background-color 0.3s ease, color 0.3s ease;
    font-size: 0.95rem;
  }

  .f-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 3rem;
    text-align: center;
    margin-bottom: 0;
  }

  .f-socials,
  .f-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .f-brand {
    text-align: center;
    font-weight: 300;
  }

  .f-socials a,
  .f-links a {
    color: #212529;
    text-decoration: none;
    font-size: 1.5rem;
    transition: color 0.3s ease;
  }

  .f-socials a:hover,
  .f-links a:hover {
    color: #0066cc;
  }

  .f-brand p {
    font-size: 1rem;
    margin: 0;
  }

  .back-to-top {
    position: absolute;
    right: 20px;
    top: 20px;
    cursor: pointer;
    font-size: 2rem;
    color: #0066cc;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .back-to-top:hover {
    transform: translateY(-4px);
    color: #004c99;
  }

  @media (max-width: 768px) {
    .f-info {
      flex-direction: column;
    }
  }
</style>

<footer id="site-footer">
  <div class="back-to-top" onclick="scrollToTop()" title="Back to Top">⬆</div>
  <div class="container">
    <div class="f-info">
      <div class="f-socials">
        <a href="https://facebook.com" target="_blank" aria-label="Facebook"><i class="fa-brands fa-facebook-square"></i></a>
        <a href="https://www.instagram.com/pradnya_j24/" target="_blank" aria-label="Instagram"><i class="fa-brands fa-instagram-square"></i></a>
        <a href="https://www.linkedin.com/in/pradnya-jadhav-173199348/" target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
      </div>
      <div class="f-brand">
        <p>© WanderLust Private Limited</p>
      </div>
      <div class="f-links">
        <a href="#" onclick="event.preventDefault()">Privacy</a>
        <a href="#" onclick="event.preventDefault()">Terms</a>
      </div>
    </div>
  </div>
</footer>

<script>
  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function toggleTheme() {
    document.body.classList.toggle('dark-mode');
    document.getElementById('site-footer').classList.toggle('dark-mode');
  }
</script>
