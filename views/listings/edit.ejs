<% layout("./layouts/boilerplate") %>

<style>
    /* Styling for Better Responsiveness */
    .edit-form-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    h2 {
        font-weight: 600;
        color: #343a40;
    }

    .form-label {
        font-weight: 500;
        color: #495057;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #ced4da;
        transition: all 0.3s;
    }

    .form-control:focus {
        border-color: #4b8ef1;
        box-shadow: 0 0 0 0.2rem rgba(75, 142, 241, 0.25);
    }

    .btn-dark {
        width: 100%;
        padding: 0.75rem;
        border-radius: 10px;
        font-weight: 500;
        transition: background-color 0.3s ease;
    }

    .btn-dark:hover {
        background-color: #000000;
    }

    .listing-img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        margin-top: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .original-listing-img {
        max-width: 150px;
        height: auto;
        border-radius: 8px;
        margin-top: 10px;
        display: block;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .invalid-feedback {
        font-size: 0.9rem;
        color: #e74c3c;
    }
</style>

<body>
  <div class="container mt-3">
      <div class="edit-form-container shadow">
          <h2 class="text-center mb-4">Edit Your Listing here!</h2>
          
          <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
              <div class="mb-3">
                  <label for="title" class="form-label">Title</label>
                  <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
                  <div class="invalid-feedback">Title should be valid!</div>
              </div>

              <div class="mb-3">
                  <label for="description" class="form-label">Description</label>
                  <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
                  <div class="invalid-feedback">Description should be valid!</div>
              </div>

              <!-- Original Image -->
              <div class="mb-3 text-center">
                  <strong>Original Listing Image</strong><br>
                  <img src="<%= orignalImageUrl %>" class="listing-img" alt="Listing Image">
              </div>

              <!-- New Image Upload -->
              <div class="mb-3">
                  <label for="image" class="form-label">Upload New Image</label>
                  <input type="file" name="listing[image]" class="form-control">
              </div>

              <!-- Price & Country Row -->
              <div class="row">
                  <div class="mb-3 col-md-4">
                      <label for="price" class="form-label">Price</label>
                      <input type="number" value="<%= listing.price %>" name="listing[price]" class="form-control" required>
                      <div class="invalid-feedback">Price should be valid!</div>
                  </div>

                  <div class="mb-3 col-md-8">
                      <label for="country" class="form-label">Country</label>
                      <input type="text" value="<%= listing.country %>" name="listing[country]" class="form-control" required>
                      <div class="invalid-feedback">Country should be valid!</div>
                  </div>
              </div>

              <!-- Location Input -->
              <div class="mb-3">
                  <label for="location" class="form-label">Location</label>
                  <input type="text" value="<%= listing.location %>" name="listing[location]" class="form-control" required>
                  <div class="invalid-feedback">Location should be valid!</div>
              </div>

              <!-- Submit Button -->
              <button class="btn btn-dark edit-btn">Submit</button>
          </form>
      </div>
  </div>
</body>

<script>
  function previewImage(event) {
    const imagePreview = document.getElementById('image-preview');
    const file = event.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        imagePreview.src = e.target.result;
        imagePreview.classList.remove('d-none');
      };
      reader.readAsDataURL(file);
    }
  }
</script>
