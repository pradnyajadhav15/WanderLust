<% layout("./layouts/boilerplate") %> 
<body>
  <style>
    #filters {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      padding: 1rem;
      background: #ffffff;
      border-radius: 16px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .filter {
      text-align: center;
      opacity: 0.8;
      transition: all 0.3s ease;
      padding: 0.75rem;
      border-radius: 12px;
      background: #f1f3f5;
      min-width: 90px;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
      background: #e9ecef;
      transform: translateY(-2px);
    }

    .filter a {
      text-decoration: none;
      color: #212529;
    }

    .filter i {
      font-size: 1.2rem;
      margin-bottom: 0.3rem;
    }

    .filter p {
      font-size: 0.85rem;
      margin: 0;
    }

    .tax-info {
      display: none;
    }

    .tex-switch {
      display: flex;
      align-items: center;
      padding: 0.5rem 1.2rem;
      border-radius: 12px;
      border: 1px solid #dee2e6;
      margin: 1.5rem auto;
      cursor: pointer;
      width: fit-content;
      background: #f8f9fa;
      box-shadow: 0 3px 6px rgba(0, 0, 0, 0.05);
    }

    .form-check-input:checked {
      background-color: #000;
      border-color: #000;
    }

    .listing-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: none;
      border-radius: 16px;
      overflow: hidden;
      background: #ffffff;
    }

    .listing-card:hover {
      transform: scale(1.015);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .card-img-top {
      height: 260px;
      object-fit: cover;
    }

    .card-body {
      padding: 1rem;
      background: #fff;
    }

    .card-text {
      font-size: 0.95rem;
      color: #343a40;
    }

    .listing-link {
      text-decoration: none;
    }

    @media (max-width: 768px) {
      .row {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .filter {
        flex: 1 1 40%;
      }

      .tex-switch {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <div id="filters">
    <% const categories = [
      { name: "Trending", icon: "fa-fire" },
      { name: "Rooms", icon: "fa-bed" },
      { name: "Iconic Cities", icon: "fa-mountain-city" },
      { name: "Mountains", icon: "fa-mountain" },
      { name: "Castles", icon: "fa-fort-awesome" },
      { name: "Amazing Pools", icon: "fa-person-swimming" },
      { name: "Camping", icon: "fa-campground" },
      { name: "Farms", icon: "fa-cow" },
      { name: "Arctic", icon: "fa-snowflake" },
      { name: "Domes", icon: "fa-igloo" }
    ]; %>

    <% for (let category of categories) { %>
      <div class="filter">
        <a href="/listings/category/<%= category.name %>">
          <div><i class="fa-solid <%= category.icon %>"></i></div>
          <p><%= category.name %></p>
        </a>
      </div>
    <% } %>
  </div>


  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <div class="tex-switch">
    <div class="form-check-reverse form-switch">

      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault" checked>

      <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
    </div>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3"> 
    <% for (let listings of allListings) { %>
      <a href="/listings/<%= listings._id %>" class="listing-link">
        <div class="card col listing-card">
          <img src="<%= listings.image.url %>" class="card-img-top" alt="listing_image">
          <div class="card-body">
            <p class="card-text">
              <b><%= listings.title %></b> <br>
              &#8377; <%= listings.price.toLocaleString("en-IN") %>/night 
              <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  </div>

  
  <script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (let info of taxInfo) {
        info.style.display = info.style.display !== "inline" ? "inline" : "none";
      }
    });
  </script>
</body>
