<% layout("/layouts/boilerplate.ejs") %>

<body>
  <!-- Top Navbar -->
  <nav class="navbar fixed-top shadow-sm px-4 py-3 bg-white d-flex justify-content-between align-items-center">
    <h4 class="m-0 fw-bold">🌍 WanderLust</h4>
    <div>
      <button class="btn btn-sm btn-outline-dark me-2" onclick="toggleDarkMode()">🌗 Dark Mode</button>
      <a href="/wishlist/" class="btn btn-sm btn-outline-danger">
        <i class="fa-solid fa-heart"></i> Wishlist
      </a>
    </div>
  </nav>

  <!-- Main Content -->
  
    <div class="search-container py-3 px-4 rounded shadow-sm bg-light mb-3">

    <!-- Search and Sorting -->
    <div class="search-container p-4 rounded shadow-sm bg-light mb-4">
      <form action="/listings/indivisual/search" method="GET">
        <div class="row g-3 align-items-center">
          <!-- Search Input -->
          <div class="col-md-6 col-sm-12">
            <input 
              type="text" 
              name="query" 
              class="form-control form-control-lg rounded-pill" 
              placeholder="Search by title, location, country..." 
              required 
            />
          </div>

          <!-- Search Button -->
          <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-4">
              <i class="fas fa-search me-2"></i> Search
            </button>
          </div>

          <!-- Sorting Buttons -->
          <div class="col-auto">
            <a href="/listings/feature/order/asc" class="btn btn-outline-secondary btn-lg rounded-pill">Price ↑</a>
          </div>
          <div class="col-auto">
            <a href="/listings/feature/order/desc" class="btn btn-outline-secondary btn-lg rounded-pill">Price ↓</a>
          </div>
        </div>
      </form>
    </div>

    <!-- Listings -->
    <% if (allListings.length > 0) { %>
      <h2 class="mb-4 text-center">✨ Explore Listings</h2>
      <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
        <% for (let listing of allListings) { %>
          <a href="/listings/<%= listing.id %>" class="listing-link text-decoration-none">
            <div class="card listing-card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
              <i 
                class="fa-heart position-absolute top-0 end-0 m-3 fs-4 
                <%= wishlistIds.includes(listing._id.toString()) ? 'fa-solid active text-danger' : 'fa-regular text-muted' %>"
                data-id="<%= listing._id %>">
              </i>
              <img 
                src="<%= listing.image.url %>" 
                class="card-img-top" 
                style="height: 200px; object-fit: cover;" 
              />
              <div class="card-body text-center">
                <h5 class="card-title fw-bold mb-2"><%= listing.title %></h5>
                <p class="text-muted mb-1">📍 <%= listing.location %>, <%= listing.country %></p>
                <p class="text-primary fw-semibold">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
              </div>
            </div>
          </a>
        <% } %>
      </div>
    <% } else { %>
      <div class="text-center mt-5">
        <h4 class="mb-3 text-muted">Oops! No listings found 🥺</h4>
        <p class="mb-4">Seems like your dream stay is playing hide and seek! 🏡🔍</p>
        <a href="/listings" class="btn btn-primary rounded-pill px-4 py-2">Get All Listings</a>
      </div>
    <% } %>
  </div>

  <!-- Scripts -->
  <script>
    // Wishlist icon toggle
    document.querySelectorAll(".fa-heart").forEach((heart) => {
      heart.addEventListener("click", async (event) => {
        event.preventDefault();
        event.stopPropagation();

        heart.classList.toggle("fa-solid");
        heart.classList.toggle("fa-regular");
        heart.classList.toggle("text-danger");
        heart.classList.toggle("text-muted");

        const listingId = heart.getAttribute("data-id");
        const res = await fetch("/wishlist/add", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ listingId }),
        });

        const data = await res.json();
        if (data.action === "added") {
          heart.classList.add("fa-solid", "text-danger");
          heart.classList.remove("fa-regular", "text-muted");
        } else {
          heart.classList.remove("fa-solid", "text-danger");
          heart.classList.add("fa-regular", "text-muted");
        }
      });
    });

    // Dark mode toggle
    function toggleDarkMode() {
      document.body.classList.toggle("bg-dark");
      document.body.classList.toggle("text-white");
      document.querySelectorAll(".card").forEach((card) => {
        card.classList.toggle("bg-dark");
        card.classList.toggle("text-white");
      });
    }
  </script>
</body>
