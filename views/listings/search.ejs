<% layout("./layouts/boilerplate") %>

<style>
  a {
    text-decoration: none;
    color: inherit;
  }

  .card-img-top {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
  }

  .listing-card {
    max-width: 360px;
    border: none;
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.07);
    background: #fff;
  }

  .listing-card:hover {
    transform: scale(1.03);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
  }

  .card-body {
    padding: 1rem;
  }

  .card-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: #343a40;
  }

  .search-title {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: #212529;
  }

  @media (max-width: 576px) {
    .listing-card {
      max-width: 100%;
    }

    .search-title {
      font-size: 1.3rem;
    }
  }
</style>

<div class="container mt-4">
  <h3 class="text-center search-title">Search Results for "<%= query %>":</h3>

  <div class="row justify-content-center" id="listingItems">
    <% if (results.length > 0) { %>
      <% results.forEach(listing => { %>
        <div class="col-lg-4 col-md-6 col-sm-12 mb-4 d-flex justify-content-center">
          <div class="card listing-card w-100">
            <a href="/listings/<%= listing._id %>">
              <img src="<%= listing.image.url || '/images/default.jpg' %>" class="card-img-top" alt="<%= listing.title %>">
              <div class="card-body text-center">
                <h5 class="card-title"><%= listing.title %></h5>
              </div>
            </a>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-center text-danger mt-4">No results found for "<%= query %>"</p>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
