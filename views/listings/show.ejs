<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listing Details</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" crossorigin="anonymous">

  <link href="https://api.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.css" rel="stylesheet">
</head>

<% layout("/layouts/boilerplate") -%>
<body>

<script src="https://api.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.js"></script>

<script nonce="<%= nonce %>">
  console.log("Nonce applied:", "<%= nonce %>");
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>


<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h3>Listing Details:</h3>
      <div class="card shadow-sm border-0 show-card">
        <img 
          src="<%= listing.image ? listing.image.url : '/images/default.jpg' %>" 
          class="card-img-top show-img"
          alt="Listing image">
        <div class="card-body text-center">
          <h5 class="card-title"><b><%- listing.title %></b></h5>
          <p class="card-text text-muted">
            <%- listing.description %> <br>
            <b>₹<%= listing.price.toLocaleString("en-IN", { minimumFractionDigits: 2 }) %></b> / night <br>
            <span class="text-muted"><%= listing.location %>, <%= listing.country %></span>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="col-8 offset-2 mb-3">
  <h3>Where you'll be</h3>
  <div id="map" class="w-100" style="height: 300px;"></div>
</div>

<!-- ✅ Ensure External Script Uses Nonce -->
<script src="/js/map.js" nonce="<%= nonce %>"></script>

</body>
</html>
