<% layout("/layouts/boilerplate") -%>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h3>Listing Details:</h3>

      <div class="card shadow-sm border-0 show-card">
        <img 
          src="<%= listing.image ? listing.image.url : '/images/default.jpg' %>" 
          class="card-img-top show-img"
          alt="Listing image">
          
        <div class="card-body text-center">
          <h5 class="card-title"><b><%= listing.title %></b></h5>
          <p class="card-text text-muted">
            <%= listing.description %> <br>
            <b>₹<%= listing.price.toLocaleString("en-IN") %></b> / night <br>
            <span class="text-muted"><%= listing.location %>, <%= listing.country %></span>
          </p>
        </div>
      </div>

      <div class="d-flex justify-content-center gap-2 mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

  <div class="col-8 offset-3 mb-3">
    <hr />
    <% if (currUser) { %>
    <h4>Leave a Review</h4>
    <form 
      action="/listings/<%= listing._id %>/reviews" 
      method="POST"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input 
          type="range" 
          id="rating" 
          name="rating"
          min="1" 
          max="5"
          class="form-range"
        >
      </div>
      
      <div class="mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea 
          id="comment" 
          name="comment" 
          rows="3" 
          class="form-control"
          placeholder="Write your review here..."
          required
        ></textarea>
      </div>

      <button type="submit" class="btn btn-dark">Submit Review</button>
    </form>
    <% } %>
    <hr />
  </div>


<div class="container mt-4">
  <h3>All Reviews</h3>
  <div class="row">
    <% if (listing.reviews.length > 0) { %>
      <% for (let review of listing.reviews) { %>
        <div class="col-md-5 mb-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= review.author ? review.author.username : "Anonymous" %></h5>
              <p class="card-text"><%= review.comment %></p>
              <p class="card-text"><%= review.rating %> ⭐</p>
              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <p class="text-muted">No reviews yet. Be the first to review!</p>
    <% } %>
  </div>
</div>