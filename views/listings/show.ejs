<% layout("/layouts/boilerplate") -%>
<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h3>Listing Details:</h3>

      <div class="card shadow-sm border-0 show-card">
        <img 
          src="<%= listing.image ? listing.image.url : '/images/default.jpg' %>" 
          class="card-img-top show-img"
          alt="Listing image">
          
        <div class="card-body text-center">
          <h5 class="card-title"><b><%= listing.title %></b></h5>
          <p class="card-text text-muted">
            <%= listing.description %> <br>
            <b>₹<%= listing.price.toLocaleString("en-IN") %></b> / night <br>
            <span class="text-muted"><%= listing.location %>, <%= listing.country %></span>
          </p>
        </div>
      </div>

      <div class="d-flex justify-content-center gap-2 mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>