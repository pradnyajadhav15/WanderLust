<style>
  /* Hover effect for cards */
.card.hover-up:hover {
  transform: translateY(-10px); /* Lift the card */
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1); /* Add a shadow */
  transition: all 0.3s ease; /* Smooth transition */
}

.card.hover-up {
  transition: all 0.3s ease; /* Ensure smooth transition even when not hovered */
}

/* Optional: Add a slight background change when hovering */
.card.hover-up:hover {
  background-color: #f8f9fa; /* Light grey background on hover */
}

</style>









<% layout("/layouts/boilerplate.ejs") %>
<body class="bg-white text-dark">

  <!-- Hero Section -->
  <section class="hero-section py-5" style="background: linear-gradient(135deg, #e0f7fa, #ffffff);">
    <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-4">
      <div class="hero-text fade-in">
        <h1 class="display-4 fw-bold text-primary mb-3">Welcome to <span class="text-gradient">WanderLust</span></h1>
        <p class="lead text-muted mb-4">
          Turn your space into a destination! List your place and connect with travelers worldwide.
        </p>
        <div class="d-flex gap-3">
          <a href="/listings/new/" class="btn btn-primary btn-lg shadow">
            <i class="fa-solid fa-plus me-2"></i> Add Listing
          </a>
          <a href="/listings" class="btn btn-outline-dark btn-lg">
            <i class="fa-solid fa-eye me-2"></i> Browse Listings
          </a>
        </div>
      </div>
      <div class="hero-image fade-in delay-1">
        <img src="https://cdn-icons-png.flaticon.com/512/201/201623.png" alt="Travel" class="img-fluid" style="max-height: 350px;">
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-5 bg-light">
    <div class="container text-center">
      <h2 class="mb-5 fade-in delay-2">
        <span class="text-primary fs-2">🌟</span> Top Categories <span class="text-primary fs-2">🌍</span>
      </h2>
      <div class="row g-4 justify-content-center">
        <% const categories = [
          { icon: "fa-mountain", name: "Mountains" },
          { icon: "fa-umbrella-beach", name: "Beaches" },
          { icon: "fa-city", name: "Cities" },
          { icon: "fa-tree", name: "Forests" },
          { icon: "fa-snowflake", name: "Snow" },
          { icon: "fa-monument", name: "Historical" }
        ]; %>
        <% categories.forEach((c, i) => { %>
          <div class="col-6 col-md-4 col-lg-2 fade-in delay-<%= i %>">
            <div class="card shadow-sm border-0 p-3 h-100 hover-up">
              <i class="fa-solid <%= c.icon %> text-primary fs-1 mb-3"></i>
              <h5 class="fw-semibold"><%= c.name %></h5>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-5 bg-white">
    <div class="container text-center">
      <h2 class="mb-3 fade-in">Our Services</h2>
      <p class="text-muted mb-5">Helping travelers and hosts get the most out of every journey.</p>
      <div class="row g-4">
        <% const services = [
          { title: "Property Listing", desc: "List your property and connect with travelers.", img: "https://cdn-icons-png.flaticon.com/512/2777/2777142.png" },
          { title: "Travel Experiences", desc: "Book unique travel experiences.", img: "https://cdn-icons-png.flaticon.com/512/869/869869.png" },
          { title: "Secure Payments", desc: "Fast, secure payment options.", img: "https://tse1.mm.bing.net/th?id=OIP.K5qj7NgVyXN-VKE4zAqBYwHaFj&pid=Api&P=0&h=180" },
          { title: "24/7 Support", desc: "Round-the-clock assistance.", img: "https://cdn-icons-png.flaticon.com/512/1256/1256650.png" }
        ]; %>
        <% services.forEach((s, i) => { %>
          <div class="col-md-6 fade-in delay-<%= i %>">
            <div class="card h-100 shadow hover-up">
              <div class="card-body d-flex align-items-center">
                <div class="flex-grow-1 text-start">
                  <h4 class="card-title fw-bold"><%= s.title %></h4>
                  <p class="text-muted"><%= s.desc %></p>
                </div>
                <img src="<%= s.img %>" alt="<%= s.title %>" width="70" class="ms-3">
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-5 bg-dark text-white">
    <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-4">
      <div class="fade-in">
        <h2 class="fw-bold">Ready to Grow Your Business?</h2>
        <p class="text-muted">Contact us today and let us help expand your reach!</p>
        <a href="/contactUs" class="btn btn-outline-light btn-lg mt-3">
          Contact Us <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
      </div>
      <div class="fade-in delay-1">
        <img src="https://tse4.mm.bing.net/th?id=OIP.FR0bNEcFkrnxhLaYrOoiiwHaEK&pid=Api&P=0&h=180" 
             class="img-fluid rounded shadow-lg" alt="CTA Image">
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-5 bg-light">
    <div class="container text-center">
      <h2 class="mb-4 fade-in">Success Stories</h2>
      <p class="text-muted mb-5">Our clients share their experiences</p>
      <div class="row g-4">
        <% const stories = [
          { icon: "fa-chart-line", name: "Tour Company", text: "We optimized a local tour company’s site and increased bookings by 70%." },
          { icon: "fa-hotel", name: "Hotel Chain", text: "Our strategy gained 50k+ followers and doubled engagement." },
          { icon: "fa-plane", name: "Travel Agency", text: "Saw a 40% increase in traffic with our SEO services." }
        ]; %>
        <% stories.forEach((story, i) => { %>
          <div class="col-md-4 fade-in delay-<%= i %>">
            <div class="card shadow h-100 p-3">
              <p class="card-text">"<%= story.text %>"</p>
              <div class="d-flex align-items-center mt-4">
                <div class="bg-primary text-white rounded-circle p-3 me-3">
                  <i class="fa-solid <%= story.icon %>"></i>
                </div>
                <h5 class="mb-0"><%= story.name %></h5>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
</body>
